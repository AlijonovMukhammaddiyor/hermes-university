# Hermes University — single source of config. Copy to config.env and fill in.
# Everything else (skills, cron prompts, docs) is rendered against these values.

# ── Identity ────────────────────────────────────────────────────────────
LEARNER_NAME="Your Name"
TIMEZONE="Asia/Tashkent"

# ── LLM provider (default DeepSeek) ─────────────────────────────────────
DEEPSEEK_API_KEY=""
LLM_MODEL="deepseek-v4-pro"          # teach/grade model

# ── Telegram (student interface) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_USERS=""            # your numeric user id
TELEGRAM_HOME_CHANNEL=""             # chat id for digests

# ── Anki (spaced repetition → phone, via genanki + AnkiWeb) ─────────────
ANKIWEB_EMAIL=""                     # password entered interactively at install
ANKI_DECK_PREFIX="Hermes University"

# ── Google Calendar (read primary / write Mentor only) ──────────────────
GOOGLE_OAUTH_CREDENTIALS="/home/hermes/.hermes/gcp-oauth.keys.json"
# MENTOR_CALENDAR_ID auto-derived at install and written back here

# ── Coding proof-gate ───────────────────────────────────────────────────
LEETCODE_SESSION=""                  # best-effort now
JUDGE0_URL=""                        # optional; real sandbox gate (later)

# ── Program shape (defaults match the RFC) ──────────────────────────────
TOTAL_SEMESTERS=2
WEEKS_PER_SEMESTER=12
DAILY_TASK_CAP=4
