# Hermes University — infrastructure & secrets. Copy to config.env and fill in (or run setup.sh).
# Your IDENTITY and GOALS live in profile.yaml (copy from profile.example.yaml), NOT here.
# setup.sh wires these into the Hermes agent (~/.hermes); this file stays the source of truth.
# Keep comments on their OWN lines — values are read verbatim, so a trailing "# ..." becomes part of the value.

# ── LLM provider (default DeepSeek) ─────────────────────────────────────
DEEPSEEK_API_KEY=""
# deepseek-v4-flash (fast, cheap — the default) or deepseek-v4-pro (stronger).
# NOTE: deepseek-chat / deepseek-reasoner are deprecated as of 2026-07-24.
LLM_MODEL="deepseek-v4-flash"

# ── Web search (REQUIRED — course research must be grounded in real sources) ──
# SERPER_API_KEY — https://serper.dev (free tier is plenty)
SERPER_API_KEY=""
# BRAVE_API_KEY — optional alternative to Serper
BRAVE_API_KEY=""

# ── Telegram (your interface to the agent) ──────────────────────────────
# TELEGRAM_BOT_TOKEN — from @BotFather
TELEGRAM_BOT_TOKEN=""
# TELEGRAM_ALLOWED_USERS — your numeric user id (from @userinfobot)
TELEGRAM_ALLOWED_USERS=""
# TELEGRAM_HOME_CHANNEL — optional: chat id for scheduled digests
TELEGRAM_HOME_CHANNEL=""

# ── Anki (OPTIONAL — spaced repetition pushed to your phone via AnkiWeb) ─
ANKIWEB_USERNAME=""
ANKIWEB_PASSWORD=""
ANKI_DECK_PREFIX="Hermes University"

# ── Google Calendar (OPTIONAL — books your study routine) ───────────────
# Path to your Desktop OAuth client json (see PREREQUISITES.md); leave as-is if unused.
GOOGLE_OAUTH_CREDENTIALS="~/.hermes/gcp-oauth.keys.json"

# ── Coding proof-gate (OPTIONAL) ────────────────────────────────────────
# LEETCODE_SESSION — best-effort LeetCode verification
LEETCODE_SESSION=""
# JUDGE0_URL — optional sandboxed code-execution gate
JUDGE0_URL=""

# ── Program shape ───────────────────────────────────────────────────────
TOTAL_SEMESTERS=2
WEEKS_PER_SEMESTER=12
# (learner name, timezone, goals, daily task cap → profile.yaml)
